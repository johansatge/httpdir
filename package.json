{
  "name": "httpdir",
  "version": "3.0.1",
  "description": "Simple, zero dependency command-line HTTP server for static local files",
  "author": "Johan Satgé",
  "type": "module",
  "bin": {
    "httpdir": "src/cli.js"
  },
  "exports": {
    ".": "./src/server.js"
  },
  "scripts": {
    "test": "vitest run --config=test/vitest.config.js --coverage"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.html",
    "src/**/*.css",
    "src/**/*.png",
    "src/**/*.ico",
    "package.json",
    "readme.md",
    "license.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johansatge/httpdir.git"
  },
  "bugs": {
    "url": "https://github.com/johansatge/httpdir/issues"
  },
  "keywords": [
    "server",
    "static",
    "local",
    "http",
    "file",
    "apache",
    "nginx",
    "command-line",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "preferGlobal": true,
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
